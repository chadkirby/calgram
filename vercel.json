{
  "build": {
    "env": {
      "APP_NAME": "jazz-react-tailwind-starter"
    }
  },
  "ignoreCommand": "node ../../ignore-vercel-build.js",
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ]
}
